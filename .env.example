# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/felicity

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRY=7d

# Password Hashing
BCRYPT_ROUNDS=12

# SMTP Email Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend URL (used in email templates)
FRONTEND_URL=http://localhost:5173

# Admin Credentials (auto-seeded on first startup)
ADMIN_EMAIL=admin@felicity.com
ADMIN_PASSWORD=Admin@123
